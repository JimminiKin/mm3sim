{
  "framework": null,
  "buildCommand": "./install.sh",
  "devCommand": null,
  "installCommand": null,
  "outputDirectory": "dist",
  "env": {
    "TRUNK_NO_HOT_RELOAD": "true"
  },
  "headers": [
    {
      "source": "/(.*)\\.wasm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/javascript"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}